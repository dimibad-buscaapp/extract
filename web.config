<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS: erros detalhados + acesso público (evita HTTP 403 para visitantes).
-->
<configuration>
  <system.webServer>
    <security>
      <authorization>
        <add accessType="Allow" users="*" />
      </authorization>
    </security>
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="index.php" />
        <add value="index.html" />
      </files>
    </defaultDocument>
    <httpErrors errorMode="Detailed" existingResponse="PassThrough" />
    <directoryBrowse enabled="false" />
  </system.webServer>
</configuration>
