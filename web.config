<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS: erros detalhados para depurar HTTP 500 com PHP.
  Em produção podes mudar errorMode para "DetailedLocalOnly" ou remover este ficheiro.
-->
<configuration>
  <system.webServer>
    <httpErrors errorMode="Detailed" existingResponse="PassThrough" />
  </system.webServer>
</configuration>
